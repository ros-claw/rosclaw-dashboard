{
  "name": "@rosclaw/eurdf-parser",
  "version": "0.1.0",
  "description": "e-URDF YAML parser and validator",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "eurdf-validate": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
